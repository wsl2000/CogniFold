# Cognifold Environment Configuration
# Copy to .env and fill in values

# --- LLM API Keys ---
GOOGLE_API_KEY=
OPENAI_API_KEY=

# --- Server ---
COGNIFOLD_HOST=127.0.0.1
COGNIFOLD_PORT=8000
COGNIFOLD_LOG_LEVEL=info
COGNIFOLD_WORKERS=2

# --- Session Storage ---
# Backend: "file" (default) or "redis"
COGNIFOLD_SESSION_BACKEND=file
COGNIFOLD_PERSIST_DIR=./sessions

# Redis (only needed when SESSION_BACKEND=redis)
COGNIFOLD_REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
# Comma-separated API keys (leave empty to disable auth)
COGNIFOLD_API_KEY=

# --- Session Limits ---
COGNIFOLD_MAX_SESSIONS=100
COGNIFOLD_SESSION_TTL_HOURS=24

# --- Supabase (optional, for persistent session storage) ---
COGNIFOLD_SUPABASE_URL=
COGNIFOLD_SUPABASE_KEY=
COGNIFOLD_ENABLE_GRAPH_SYNC=false
COGNIFOLD_SESSION_BACKEND=memory

# --- Cloud Run Overrides ---
# These are set automatically by the CD workflow for Cloud Run deploys.
# Uncomment to test locally with Cloud Run-like settings.
# COGNIFOLD_WORKERS=1
# COGNIFOLD_TIMEOUT=300
# COGNIFOLD_SESSION_BACKEND=redis
# COGNIFOLD_REDIS_URL=redis://MEMORYSTORE_IP:6379/0
